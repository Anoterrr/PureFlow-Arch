# --- Storage Configuration (MinIO / S3) ---
STORAGE_USER=admin
STORAGE_PASSWORD=strongpassword123
S3_ENDPOINT=http://localhost:9000

# --- Processing Configuration (DuckDB) ---
# Absolute path recommended for Docker consistency
DUCKDB_PATH=data/pureflow_lakehouse.db

# --- Pipeline & Date Configuration ---
# BASE_DATE: Used by static config for partitioning logic
BASE_DATE=2026-04-19
# EXECUTION_DATE: Used by Dashboard and ad-hoc ingestion scripts
EXECUTION_DATE=2026-04-19

# --- S3 Bucket Names (Medallion Architecture) ---
S3_BUCKET_LANDING=landing-zone
S3_BUCKET_BRONZE=bronze
S3_BUCKET_SILVER=silver
S3_BUCKET_GOLD=gold
S3_BUCKET_QUARANTINE=quarantine
