# --- Poetry & Dependency Managers ---
# poetry.lock is NOT ignored (it ensures reproducible builds)
# .python-version is removed as per project cleanup

# --- IDEs & Editors ---
.vscode/
.idea/
*.swp
*.swo

# --- PureFlow-Arch Project Specific ---

# 1. Data Storage (MinIO / S3 Simulated)
# Ignore all data except the .gitkeep to preserve directory structure
data/*
!data/.gitkeep
# Ignore local MinIO persistent volume
data/minio_data/

# 2. Processing Engine (DuckDB)
# Ignore local database files and write-ahead logs
*.db
*.db.wal
*.duckdb
*.duckdb.wal

# 3. Transformation Layer (dbt)
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/profiles.yml
# dbt-specific ignored files
target/
dbt_packages/

# 4. Orchestration Layer (Dagster)
dagster_home/
.dagster/
storage/

# 5. Quality & Validation (Great Expectations)
# Ignore uncommitted checkpoints and generated data docs
gx/uncommitted/
gx/logs/

# 6. Docker
.dockerignore
# (Keep the dockerfile and compose files)
