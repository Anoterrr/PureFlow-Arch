[MASTER]
# Add 'src' and root to the path so pylint can find modules and tests
init-hook='import sys; sys.path.extend(["src", "."])'

[MESSAGES CONTROL]
disable=
    raw-checker-failed,
    bad-inline-option,
    locally-disabled,
    file-ignored,
    suppressed-message,
    useless-suppression,
    deprecated-pragma,
    use-symbolic-message-instead

[TYPECHECK]
# Ignore missing members for dynamic libraries
ignored-modules=airflow,great_expectations,duckdb,pandas,numpy,pytest

[DESIGN]
max-locals=20
max-attributes=10
